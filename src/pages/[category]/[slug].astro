---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getArticles, getCategories, getArticle } from "../../utils/api";
import type { Article, Category } from "../../utils/api";
import { formatShortDate, formatLongDate } from "../../utils/date";

export const prerender = false;

type NavLink = { slug: string; titleEn: string; titleEs: string };

const { category: categorySlug, slug } = Astro.params;

const [categories, article] = await Promise.all([
  getCategories(),
  getArticle(slug as string),
]);

const navLinks: NavLink[] = categories.map((c: Category) => ({
  slug: c.slug,
  titleEn: c.titleEn,
  titleEs: c.titleEs,
}));

if (!article || article.category !== categorySlug) {
  return Astro.redirect("/404");
}

const categoryData = categories.find((c: Category) => c.slug === categorySlug);

const allCategoryArticles = await getArticles(categorySlug);

const relatedArticles: Article[] = allCategoryArticles
  .filter((a: Article) => a.slug !== slug)
  .sort((a: Article, b: Article) => {
    if (b.priority !== a.priority) return b.priority - a.priority;
    return new Date(b.date ?? 0).getTime() - new Date(a.date ?? 0).getTime();
  });

const latestRelated = relatedArticles.slice(0, 2);
const moreRelated = relatedArticles.slice(2, 8);
const catSlug = categorySlug as string;
const catEn = categoryData?.titleEn ?? catSlug;
const catEs = categoryData?.titleEs ?? catSlug;
---

<BaseLayout
  navLinks={navLinks}
  pageTitle={`${article.titleEn} | Brickell News`}
  descriptionEn={article.summaryEn ?? ""}
  descriptionEs={article.summaryEs ?? ""}
  ogImage={article.image ?? undefined}
>

  <div class="container art-page">

    <!-- Breadcrumb -->
    <nav class="art-breadcrumb">
      <a href="/">
        <span class="lang lang-en">Home</span>
        <span class="lang lang-es">Inicio</span>
      </a>
      <span class="art-breadcrumb-sep">/</span>
      <a href={`/${catSlug}`}>
        <span class="lang lang-en">{catEn}</span>
        <span class="lang lang-es">{catEs}</span>
      </a>
    </nav>

    <!-- Main Article -->
    <article class="art-main">
      <div class="art-meta">
        <span class="art-category-badge">
          <span class="lang lang-en">{catEn}</span>
          <span class="lang lang-es">{catEs}</span>
        </span>
        <span class="art-date">
          <span class="lang lang-en">{formatLongDate(article.date ?? "").en}</span>
          <span class="lang lang-es">{formatLongDate(article.date ?? "").es}</span>
        </span>
      </div>

      <h1 class="art-title">
        <span class="lang lang-en">{article.titleEn}</span>
        <span class="lang lang-es">{article.titleEs}</span>
      </h1>

      <div class="art-author-line">
        <span class="art-author">{article.author}</span>
      </div>

      <div class="art-hero-img">
        <img
          src={article.image}
          alt={article.titleEn}
          transition:name={`article-img-${article.slug}`}
        />
      </div>

      <div class="art-body">
        <p>
          <span class="lang lang-en">{article.summaryEn}</span>
          <span class="lang lang-es">{article.summaryEs}</span>
        </p>
        {article.bodyEn && (
          <div class="lang lang-block lang-en" set:html={article.bodyEn} />
        )}
        {article.bodyEs && (
          <div class="lang lang-block lang-es" set:html={article.bodyEs} />
        )}
      </div>
    </article>

    <!-- Latest from same category -->
    {latestRelated.length > 0 && (
      <section class="art-related">
        <h2 class="section-title">
          <span class="lang lang-en">Latest in {catEn}</span>
          <span class="lang lang-es">Últimas en {catEs}</span>
        </h2>
        <div class="art-related-grid">
          {latestRelated.map((rel) => (
            <a href={`/${catSlug}/${rel.slug}`} class="art-related-card">
              <div class="art-related-img">
                <img
                  src={rel.image}
                  alt={rel.titleEn}
                  loading="lazy"
                  transition:name={`article-img-${rel.slug}`}
                />
              </div>
              <div class="art-related-body">
                <span class="art-related-date">
                  <span class="lang lang-en">{formatShortDate(rel.date ?? "").en}</span>
                  <span class="lang lang-es">{formatShortDate(rel.date ?? "").es}</span>
                </span>
                <h3>
                  <span class="lang lang-en">{rel.titleEn}</span>
                  <span class="lang lang-es">{rel.titleEs}</span>
                </h3>
                <p>
                  <span class="lang lang-en">{rel.summaryEn}</span>
                  <span class="lang lang-es">{rel.summaryEs}</span>
                </p>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- More from same category -->
    {moreRelated.length > 0 && (
      <section class="art-more">
        <h2 class="section-title">
          <span class="lang lang-en">More from {catEn}</span>
          <span class="lang lang-es">Más de {catEs}</span>
        </h2>
        <div class="cat-grid">
          {moreRelated.map((rel) => (
            <a href={`/${catSlug}/${rel.slug}`} class="cat-card">
              <div class="cat-card-img">
                <img
                  src={rel.image}
                  alt={rel.titleEn}
                  loading="lazy"
                  transition:name={`article-img-${rel.slug}`}
                />
              </div>
              <div class="cat-card-body">
                <span class="cat-card-date">
                  <span class="lang lang-en">{formatShortDate(rel.date ?? "").en}</span>
                  <span class="lang lang-es">{formatShortDate(rel.date ?? "").es}</span>
                </span>
                <h3>
                  <span class="lang lang-en">{rel.titleEn}</span>
                  <span class="lang lang-es">{rel.titleEs}</span>
                </h3>
                <p>
                  <span class="lang lang-en">{rel.summaryEn}</span>
                  <span class="lang lang-es">{rel.summaryEs}</span>
                </p>
                <span class="cat-card-author">{rel.author}</span>
              </div>
            </a>
          ))}
        </div>
        <div class="art-more-link">
          <a href={`/${catSlug}`}>
            <span class="lang lang-en">View all {catEn} articles &rarr;</span>
            <span class="lang lang-es">Ver todos los artículos de {catEs} &rarr;</span>
          </a>
        </div>
      </section>
    )}

  </div>

</BaseLayout>
