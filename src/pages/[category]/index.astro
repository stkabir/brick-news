---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getArticles, getCategories } from "../../utils/api";
import type { Article, Category } from "../../utils/api";
import { formatShortDate } from "../../utils/date";

export const prerender = false;

type NavLink = { slug: string; titleEn: string; titleEs: string };

const { category: categorySlug } = Astro.params;

const [categories, articleEntries] = await Promise.all([
  getCategories(),
  getArticles(),
]);

const navLinks: NavLink[] = categories.map((c: Category) => ({
  slug: c.slug,
  titleEn: c.titleEn,
  titleEs: c.titleEs,
}));

const category = categories.find((c: Category) => c.slug === categorySlug);

if (!category) {
  return Astro.redirect("/404");
}

const articles: Article[] = articleEntries
  .filter((a: Article) => a.category === categorySlug)
  .sort((a: Article, b: Article) => {
    if (b.priority !== a.priority) return b.priority - a.priority;
    return new Date(b.date ?? 0).getTime() - new Date(a.date ?? 0).getTime();
  });

const featured = articles[0];
const rest = articles.slice(1);
---

<BaseLayout
  navLinks={navLinks}
  pageTitle={`${category.titleEn} | Brickell News`}
  descriptionEn={`Latest ${category.titleEn} news from Brickell.`}
  descriptionEs={`Últimas noticias de ${category.titleEs} en Brickell.`}
>

  <div class="container cat-page">

    <!-- Category Header -->
    <div class="cat-header">
      <h1 class="cat-title">
        <span class="lang lang-en">{category.titleEn}</span>
        <span class="lang lang-es">{category.titleEs}</span>
      </h1>
      <p class="cat-count">
        <span class="lang lang-en">{articles.length} {articles.length === 1 ? 'article' : 'articles'}</span>
        <span class="lang lang-es">{articles.length} {articles.length === 1 ? 'artículo' : 'artículos'}</span>
      </p>
    </div>

    <!-- Featured Article -->
    {featured && (
      <a href={`/${category.slug}/${featured.slug}`} class="cat-featured">
        <div class="cat-featured-img">
          <img
            src={featured.image}
            alt={featured.titleEn}
            transition:name={`article-img-${featured.slug}`}
          />
        </div>
        <div class="cat-featured-body">
          <span class="cat-featured-date">
            <span class="lang lang-en">{formatShortDate(featured.date ?? "").en}</span>
            <span class="lang lang-es">{formatShortDate(featured.date ?? "").es}</span>
          </span>
          <h2>
            <span class="lang lang-en">{featured.titleEn}</span>
            <span class="lang lang-es">{featured.titleEs}</span>
          </h2>
          <p>
            <span class="lang lang-en">{featured.summaryEn}</span>
            <span class="lang lang-es">{featured.summaryEs}</span>
          </p>
          <span class="cat-featured-author">{featured.author}</span>
        </div>
      </a>
    )}

    <!-- Article Grid -->
    {rest.length > 0 && (
      <div class="cat-grid">
        {rest.map((article) => (
          <a href={`/${category.slug}/${article.slug}`} class="cat-card">
            <div class="cat-card-img">
              <img
                src={article.image}
                alt={article.titleEn}
                loading="lazy"
                transition:name={`article-img-${article.slug}`}
              />
            </div>
            <div class="cat-card-body">
              <span class="cat-card-date">
                <span class="lang lang-en">{formatShortDate(article.date ?? "").en}</span>
                <span class="lang lang-es">{formatShortDate(article.date ?? "").es}</span>
              </span>
              <h3>
                <span class="lang lang-en">{article.titleEn}</span>
                <span class="lang lang-es">{article.titleEs}</span>
              </h3>
              <p>
                <span class="lang lang-en">{article.summaryEn}</span>
                <span class="lang lang-es">{article.summaryEs}</span>
              </p>
              <span class="cat-card-author">{article.author}</span>
            </div>
          </a>
        ))}
      </div>
    )}

    {articles.length === 0 && (
      <div class="cat-empty">
        <p>
          <span class="lang lang-en">No articles in this category yet.</span>
          <span class="lang lang-es">Aún no hay artículos en esta categoría.</span>
        </p>
      </div>
    )}

  </div>

</BaseLayout>
