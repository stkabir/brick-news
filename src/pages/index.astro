---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getArticles, getCategories, getSections } from "../utils/api";
import type { Article, Category, Section } from "../utils/api";
import { formatShortDate } from "../utils/date";

type NavLink = { slug: string; titleEn: string; titleEs: string };
type CategoryMeta = { titleEn: string; titleEs: string };
type EnrichedArticle = {
  article: Article;
  categoryMeta: CategoryMeta;
  formattedDate: { en: string; es: string };
};

const [categories, sections, articleEntries] = await Promise.all([
  getCategories().catch(() => [] as import('../utils/api').Category[]),
  getSections().catch(() => [] as import('../utils/api').Section[]),
  getArticles().catch(() => [] as import('../utils/api').Article[]),
]);

const navLinks: NavLink[] = categories.map((c: Category) => ({
  slug: c.slug,
  titleEn: c.titleEn,
  titleEs: c.titleEs,
}));

const categoryMap = new Map<string, Category>(
  categories.map((c: Category) => [c.slug, c])
);

const getCategoryMeta = (slug: string): CategoryMeta => {
  const c = categoryMap.get(slug);
  return {
    titleEn: c?.titleEn ?? slug,
    titleEs: c?.titleEs ?? slug,
  };
};

const sortArticles = (a: Article, b: Article) => {
  if (b.priority !== a.priority) return b.priority - a.priority;
  return new Date(b.date ?? 0).getTime() - new Date(a.date ?? 0).getTime();
};

const enrichArticle = (a: Article): EnrichedArticle => ({
  article: a,
  categoryMeta: getCategoryMeta(a.category),
  formattedDate: formatShortDate(a.date ?? ""),
});

const articleUrl = (a: EnrichedArticle) => `/${a.article.category}/${a.article.slug}`;

// All articles sorted by priority
const allArticles = [...articleEntries].sort(sortArticles).map(enrichArticle);

// Sections grouped by layout
const groupedSections = [...sections]
  .sort((a: Section, b: Section) => a.order - b.order)
  .map((s: Section) => ({
    slug: s.slug,
    sectionLayout: s.sectionLayout,
    titleEn: s.titleEn,
    titleEs: s.titleEs,
    descriptionEn: s.descriptionEn,
    descriptionEs: s.descriptionEs,
    articles: articleEntries
      .filter((a: Article) => s.categories.includes(a.category))
      .sort(sortArticles)
      .map(enrichArticle),
  }));

const trendingSection = groupedSections.find((s) => s.sectionLayout === "grid");
const trendingArticles = trendingSection?.articles || [];

// Unique category tabs for trending
const seenCats = new Set<string>();
const trendingTabs = trendingArticles
  .filter((a) => {
    if (seenCats.has(a.article.category)) return false;
    seenCats.add(a.article.category);
    return true;
  })
  .map((a) => ({ ...a.categoryMeta, slug: a.article.category }));

// Banner article (first business article, fallback to first article)
const bannerArticle =
  allArticles.find((a) => a.article.category === "business") || allArticles[0];

// More news: list + sidebar sections
const listSection = groupedSections.find((s) => s.sectionLayout === "list");
const sidebarSection = groupedSections.find((s) => s.sectionLayout === "sidebar");
const moreListArticles = [
  ...(listSection?.articles || []),
  ...(sidebarSection?.articles || []),
].slice(0, 8);
const moreFeatureArticles = (sidebarSection?.articles || []).slice(0, 2);
const moreRightArticles = (sidebarSection?.articles || []).slice(2, 8);
---

<BaseLayout
  navLinks={navLinks}
  pageTitle="Brickell News"
  descriptionEn="Miami at the Center. World in Focus. Breaking international news & geopolitics Lifestyle | Community | Environment"
  descriptionEs="Miami en el Centro. Últimas noticias internacionales y geopolítica Estilo de vida | Comunidad | Medio Ambiente"
>

  <!-- ══════ HERO ══════ -->
  <div class="container hero-section">
    <div class="hero-grid">

      <!-- Left: Featured -->
      <div class="story-featured">
        {allArticles.slice(0, 3).map((article, index) => (
          <a href={articleUrl(article)} class={index === 0 ? "featured-main" : "featured-secondary"}>
            {index === 0 && (
              <span class="badge-breaking">
                <span class="lang lang-en">Breaking News</span>
                <span class="lang lang-es">Últimas novedades</span>
              </span>
            )}
            <h1 class={index === 0 ? "" : "featured-title"}>
              <span class="lang lang-en">{article.article.titleEn}</span>
              <span class="lang lang-es">{article.article.titleEs}</span>
            </h1>
            <img
              src={article.article.image}
              alt={article.article.titleEn}
              transition:name={`article-img-${article.article.slug}`}
            />
            <p>
              <span class="lang lang-en">{article.article.summaryEn}</span>
              <span class="lang lang-es">{article.article.summaryEs}</span>
            </p>
          </a>
        ))}
      </div>

      <!-- Center -->
      <div class="story-center">
        {/* First group: 1 full-width + 2 half-width */}
        {allArticles[3] && (
          <div class="center-group">
            <a href={articleUrl(allArticles[3])} class="center-main">
              <img
                src={allArticles[3].article.image}
                alt={allArticles[3].article.titleEn}
                style="width:100%;height:170px;border-radius:6px;margin-bottom:10px;object-fit:cover;"
                transition:name={`article-img-${allArticles[3].article.slug}`}
              />
              <h3>
                <span class="lang lang-en">{allArticles[3].article.titleEn}</span>
                <span class="lang lang-es">{allArticles[3].article.titleEs}</span>
              </h3>
            </a>
            <div class="sub-stories">
              {allArticles.slice(4, 6).map((subArticle) => (
                <a href={articleUrl(subArticle)} class="sub-story">
                  <img
                    src={subArticle.article.image}
                    alt={subArticle.article.titleEn}
                    style="width:100%;height:80px;border-radius:4px;margin-bottom:6px;object-fit:cover;"
                    transition:name={`article-img-${subArticle.article.slug}`}
                  />
                  <p>
                    <span class="lang lang-en">{subArticle.article.titleEn}</span>
                    <span class="lang lang-es">{subArticle.article.titleEs}</span>
                  </p>
                </a>
              ))}
            </div>
          </div>
        )}

        {/* Second group: 1 full-width + 2 half-width */}
        {allArticles[6] && (
          <div class="center-group">
            <a href={articleUrl(allArticles[6])} class="center-main">
              <img
                src={allArticles[6].article.image}
                alt={allArticles[6].article.titleEn}
                style="width:100%;height:170px;border-radius:6px;margin-bottom:10px;object-fit:cover;"
                transition:name={`article-img-${allArticles[6].article.slug}`}
              />
              <h3>
                <span class="lang lang-en">{allArticles[6].article.titleEn}</span>
                <span class="lang lang-es">{allArticles[6].article.titleEs}</span>
              </h3>
            </a>
            <div class="sub-stories">
              {allArticles.slice(7, 9).map((subArticle) => (
                <a href={articleUrl(subArticle)} class="sub-story">
                  <img
                    src={subArticle.article.image}
                    alt={subArticle.article.titleEn}
                    style="width:100%;height:80px;border-radius:4px;margin-bottom:6px;object-fit:cover;"
                    transition:name={`article-img-${subArticle.article.slug}`}
                  />
                  <p>
                    <span class="lang lang-en">{subArticle.article.titleEn}</span>
                    <span class="lang lang-es">{subArticle.article.titleEs}</span>
                  </p>
                </a>
              ))}
            </div>
          </div>
        )}

        {/* Third group: 1 full-width + 2 half-width */}
        {allArticles[9] && (
          <div class="center-group">
            <a href={articleUrl(allArticles[9])} class="center-main">
              <img
                src={allArticles[9].article.image}
                alt={allArticles[9].article.titleEn}
                style="width:100%;height:170px;border-radius:6px;margin-bottom:10px;object-fit:cover;"
                transition:name={`article-img-${allArticles[9].article.slug}`}
              />
              <h3>
                <span class="lang lang-en">{allArticles[9].article.titleEn}</span>
                <span class="lang lang-es">{allArticles[9].article.titleEs}</span>
              </h3>
            </a>
            <div class="sub-stories">
              {allArticles.slice(10, 12).map((subArticle) => (
                <a href={articleUrl(subArticle)} class="sub-story">
                  <img
                    src={subArticle.article.image}
                    alt={subArticle.article.titleEn}
                    style="width:100%;height:80px;border-radius:4px;margin-bottom:6px;object-fit:cover;"
                    transition:name={`article-img-${subArticle.article.slug}`}
                  />
                  <p>
                    <span class="lang lang-en">{subArticle.article.titleEn}</span>
                    <span class="lang lang-es">{subArticle.article.titleEs}</span>
                  </p>
                </a>
              ))}
            </div>
          </div>
        )}
      </div>

      <!-- Right -->
      <div class="story-right">
        {allArticles.slice(15, 21).map((article) => (
          <a href={articleUrl(article)} class="top-story">
            <img
              src={article.article.image}
              alt={article.article.titleEn}
              style="width:100px;height:70px;border-radius:4px;flex-shrink:0;object-fit:cover;"
              transition:name={`article-img-${article.article.slug}`}
            />
            <div class="top-story-text">
              <h4>
                <span class="lang lang-en">{article.article.titleEn}</span>
                <span class="lang lang-es">{article.article.titleEs}</span>
              </h4>
              <p>
                <span class="lang lang-en">{article.article.summaryEn}</span>
                <span class="lang lang-es">{article.article.summaryEs}</span>
              </p>
            </div>
          </a>
        ))}
        <ul class="side-list">
          {allArticles.slice(21, 31).map((article) => (
            <li><a href={articleUrl(article)}>
              <span class="lang lang-en">{article.article.titleEn}</span>
              <span class="lang lang-es">{article.article.titleEs}</span>
            </a></li>
          ))}
        </ul>
      </div>

    </div>
  </div>

  <!-- ══════ BANNER ══════ -->
  {bannerArticle && (
    <div class="container">
      <div class="feature-banner">
        <video class="banner-bg" src="/img/vid-brickell.mp4" autoplay loop muted playsinline></video>
        <div class="banner-content">
          <div>
            <span class="banner-cat">
              <span class="lang lang-en">{bannerArticle.categoryMeta.titleEn}</span>
              <span class="lang lang-es">{bannerArticle.categoryMeta.titleEs}</span>
            </span>
            <span class="banner-date">
              <span class="lang lang-en">{bannerArticle.formattedDate.en}</span>
              <span class="lang lang-es">{bannerArticle.formattedDate.es}</span>
            </span>
          </div>
          <h2>
            <span class="lang lang-en">{bannerArticle.article.titleEn}</span>
            <span class="lang lang-es">{bannerArticle.article.titleEs}</span>
          </h2>
          <p>
            <span class="lang lang-en">{bannerArticle.article.summaryEn}</span>
            <span class="lang lang-es">{bannerArticle.article.summaryEs}</span>
          </p>
          <a href={articleUrl(bannerArticle)} class="btn-read">
            <span class="lang lang-en">Read Story &#9658;</span>
            <span class="lang lang-es">Leer Historia &#9658;</span>
          </a>
        </div>
      </div>
    </div>
  )}

  <!-- ══════ MORE NEWS ══════ -->
  <div class="container more-section">
    <h2 class="section-title">
      <span class="lang lang-en">More News</span>
      <span class="lang lang-es">Más noticias</span>
    </h2>
    <div class="more-grid">

      <!-- Left list -->
      <div class="more-list">
        {moreListArticles.map((article) => (
          <a href={articleUrl(article)} class="more-list-item">
            <img
              src={article.article.image}
              alt={article.article.titleEn}
              style="width:60px;height:48px;border-radius:4px;flex-shrink:0;object-fit:cover;"
              transition:name={`article-img-${article.article.slug}`}
            />
            <p>
              <span class="lang lang-en">{article.article.titleEn}</span>
              <span class="lang lang-es">{article.article.titleEs}</span>
            </p>
          </a>
        ))}
      </div>

      <!-- Center feature -->
      <div class="more-feature">
        {moreFeatureArticles.map((article) => (
          <a href={articleUrl(article)} class="more-feature-item">
            <img
              src={article.article.image}
              alt={article.article.titleEn}
              style="width:100%;height:200px;border-radius:8px;margin-bottom:14px;object-fit:cover;"
              transition:name={`article-img-${article.article.slug}`}
            />
            <h3>
              <span class="lang lang-en">{article.article.titleEn}</span>
              <span class="lang lang-es">{article.article.titleEs}</span>
            </h3>
            <p>
              <span class="lang lang-en">{article.article.summaryEn}</span>
              <span class="lang lang-es">{article.article.summaryEs}</span>
            </p>
          </a>
        ))}
      </div>

      <!-- Right -->
      <div class="more-right">
        {moreRightArticles.map((article, i) => (
          <a href={articleUrl(article)} class="more-right-item" style={i > 1 ? "padding-top:14px;" : ""}>
            {i < 2 && (
              <img
                src={article.article.image}
                alt={article.article.titleEn}
                style="width:100%;height:70px;border-radius:4px;margin-bottom:8px;object-fit:cover;"
                transition:name={`article-img-${article.article.slug}`}
              />
            )}
            <h4>
              <span class="lang lang-en">{article.article.titleEn}</span>
              <span class="lang lang-es">{article.article.titleEs}</span>
            </h4>
            {i < 2 && (
              <p>
                <span class="lang lang-en">{article.article.summaryEn}</span>
                <span class="lang lang-es">{article.article.summaryEs}</span>
              </p>
            )}
          </a>
        ))}
      </div>

    </div>
  </div>

  <!-- ══════ TRENDING CAROUSEL ══════ -->
  <div class="trending-section">
    <div class="container">
      <div class="trending-header">
        <div>
          <p class="trending-label">
            <span class="lang lang-en">{trendingSection?.titleEn || "Trending Developments"}</span>
            <span class="lang lang-es">{trendingSection?.titleEs || "Desarrollos en Tendencia"}</span>
          </p>
          <p class="trending-subtitle">
            <span class="lang lang-en">{trendingSection?.descriptionEn || "The projects and deals shaping Brickell's skyline."}</span>
            <span class="lang lang-es">{trendingSection?.descriptionEs || "Los proyectos y acuerdos que moldean el horizonte de Brickell."}</span>
          </p>
        </div>
        <div class="trending-tabs">
          {trendingTabs.map((tab, i) => (
            <span class={`tab${i === 0 ? " active" : ""}`} data-category={tab.slug}>
              <span class="lang lang-en">{tab.titleEn}</span>
              <span class="lang lang-es">{tab.titleEs}</span>
            </span>
          ))}
        </div>
      </div>

      <div class="splide" id="trendingSlider">
        <div class="splide__track">
          <ul class="splide__list">
            {trendingArticles.map((article) => (
              <li class="splide__slide" data-category={article.article.category}>
                <a href={articleUrl(article)} class="trend-card">
                  <div class="trend-card-img">
                    <img
                      src={article.article.image}
                      alt={article.article.titleEn}
                      loading="lazy"
                      transition:name={`article-img-${article.article.slug}`}
                    />
                    <span class="card-badge">
                      <span class="lang lang-en">{article.categoryMeta.titleEn}</span>
                      <span class="lang lang-es">{article.categoryMeta.titleEs}</span>
                    </span>
                  </div>
                  <div class="trend-card-body">
                    <h4>
                      <span class="lang lang-en">{article.article.titleEn}</span>
                      <span class="lang lang-es">{article.article.titleEs}</span>
                    </h4>
                    <p>
                      <span class="lang lang-en">{article.article.summaryEn}</span>
                      <span class="lang lang-es">{article.article.summaryEs}</span>
                    </p>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>

  <script>
    import Splide from '@splidejs/splide';
    import '@splidejs/splide/css';

    const slider = new Splide('#trendingSlider', {
      type: 'loop',
      perPage: 3,
      perMove: 3,
      gap: '20px',
      pagination: true,
      arrows: true,
      autoplay: true,
      interval: 4000,
      pauseOnHover: true,
      breakpoints: {
        768: { perPage: 1 },
      },
    });

    slider.mount();

    // Tab toggle
    const tabs = document.querySelectorAll<HTMLElement>('.tab');
    const slides = document.querySelectorAll<HTMLElement>('.splide__slide[data-category]:not(.splide__slide--clone)');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        tabs.forEach(t => t.classList.remove('active'));
        tab.classList.add('active');

        const cat = tab.dataset.category;
        const targetIndex = Array.from(slides).findIndex(s => s.dataset.category === cat);
        slider.go(targetIndex >= 0 ? targetIndex : 0);
      });
    });
  </script>

</BaseLayout>
