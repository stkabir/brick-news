---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection, type CollectionEntry } from "astro:content";

type CategoryEntry = CollectionEntry<"categories">;

const categoryEntries = await getCollection("categories");
const navLinks = categoryEntries.map((c: CategoryEntry) => ({
  slug: c.id,
  titleEn: c.data.titleEn,
  titleEs: c.data.titleEs,
}));
---

<BaseLayout
  navLinks={navLinks}
  pageTitle="Page Not Found | Brickell News"
  descriptionEn="The page you are looking for does not exist."
  descriptionEs="La página que buscas no existe."
>
  <div class="container" style="text-align:center;padding:80px 20px;">
    <h1 style="font-size:6rem;margin:0;line-height:1;">404</h1>
    <p style="font-size:1.25rem;margin:16px 0 32px;">
      <span class="lang lang-en">The page you are looking for does not exist.</span>
      <span class="lang lang-es">La página que buscas no existe.</span>
    </p>
    <a href="/" style="font-weight:700;text-decoration:underline;">
      <span class="lang lang-en">← Back to Home</span>
      <span class="lang lang-es">← Volver al inicio</span>
    </a>
  </div>
</BaseLayout>
